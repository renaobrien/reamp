{
  "name": "@reamp/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main/index.cjs && esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "build:renderer": "vite build",
    "build": "pnpm build:main && pnpm build:renderer",
    "start": "pnpm build && electron ."
  },
  "dependencies": {
    "@reamp/adapters": "workspace:*",
    "@reamp/skins": "workspace:*",
    "@reamp/vis-engine": "workspace:*",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "webamp": "^2.3.1"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "esbuild": "^0.28.1",
    "vite": "^8.1.4"
  }
}
