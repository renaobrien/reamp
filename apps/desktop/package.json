{
  "name": "@reamp/desktop",
  "version": "0.2.2",
  "private": true,
  "description": "A Winamp-style player and visualizer for Spotify and Apple Music",
  "author": "renaobrien",
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main/index.cjs && esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.cjs",
    "build:renderer": "vite build",
    "build": "node scripts/write-build-info.mjs && pnpm build:main && pnpm build:renderer",
    "start": "pnpm build && electron .",
    "demo": "vite dev",
    "dist": "pnpm build && electron-builder --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@reamp/adapters": "workspace:*",
    "@reamp/skins": "workspace:*",
    "@reamp/vis-engine": "workspace:*",
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "jszip": "^3.10.1",
    "webamp": "^2.3.1"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "vite": "^8.1.4"
  }
}
